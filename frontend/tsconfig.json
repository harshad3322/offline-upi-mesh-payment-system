{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "allowJs": false,
    "strict": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["src"],

  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}